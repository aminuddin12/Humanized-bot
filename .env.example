# --- AUTH CONFIGURATION ---
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# --- EXTERNAL VENDORS ---
WA_API_KEY=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FRONTEND_URL="http://localhost:3000"
