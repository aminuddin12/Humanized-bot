# --- DATABASE CONFIGURATION ---
DB_CONNECTION=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=root
DB_PASSWORD=rootpassword
DB_NAME=humanized_bot

# Prisma Connection String (Tetap dibutuhkan oleh Prisma CLI)
