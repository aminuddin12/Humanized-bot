{
  "base": "transition-all duration-300",
  "variants": {
    "display": {
      "flex": "flex",
      "grid": "grid",
      "block": "block",
      "inline": "inline",
      "inline-flex": "inline-flex",
      "none": "hidden"
    },
    "flexDirection": {
      "row": "flex-row",
      "col": "flex-col"
    },
    "flexWrap": {
      "wrap": "flex-wrap",
      "nowrap": "flex-nowrap"
    },
    "alignItems": {
      "start": "items-start",
      "center": "items-center",
      "end": "items-end",
      "stretch": "items-stretch"
    },
    "justifyContent": {
      "start": "justify-start",
      "center": "justify-center",
      "end": "justify-end",
      "between": "justify-between"
    },
    "gap": {
      "none": "gap-0",
      "xs": "gap-2",
      "sm": "gap-4",
      "md": "gap-8",
      "lg": "gap-12",
      "xl": "gap-16"
    },
    "position": {
      "relative": "relative",
      "absolute": "absolute",
      "fixed": "fixed",
      "sticky": "sticky"
    },
    "overflow": {
      "hidden": "overflow-hidden",
      "auto": "overflow-auto",
      "visible": "overflow-visible"
    },
    "zIndex": {
      "0": "z-0",
      "10": "z-10",
      "20": "z-20",
      "30": "z-30",
      "40": "z-40",
      "50": "z-50"
    },
    "background": {
      "none": "",
      "dark": "bg-alan-dark dark:bg-black",
      "white": "bg-white dark:bg-dark-surface",
      "emerald": "bg-emerald-500 dark:bg-emerald-600"
    },
    "animation": {
      "none": "",
      "float-slow": "animate-float-slow",
      "float-fast": "animate-float-fast",
      "pulse": "animate-pulse"
    },
    "inset": {
      "none": "",
      "center": "top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2",
      "top-left": "top-0 left-0",
      "top-right": "top-0 right-0",
      "bottom-left": "bottom-0 left-0",
      "bottom-right": "bottom-0 right-0",
      "full": "inset-0",
      "top-left-hero": "-top-40 -left-40",
      "top-right-hero": "-top-40 -right-40",
      "floating-top-left": "-top-10 -left-10",
      "floating-bottom-right": "-bottom-10 -right-10"
    }
  },
  "defaultVariants": {
    "display": "block",
    "position": "relative",
    "background": "none"
  }
}
