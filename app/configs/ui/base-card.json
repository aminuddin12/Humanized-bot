{
  "base": "transition-all duration-500 relative overflow-hidden",
  "variants": {
    "variant": {
      "default": "bg-white border border-gray-100 shadow-xl shadow-gray-200/50",
      "glass": "glass shadow-2xl shadow-teal-900/5",
      "surface": "bg-teal-50/50 border border-teal-100 shadow-inner",
      "featured": "bg-secondary text-white border-2 border-primary shadow-2xl shadow-primary/20",
      "white": "bg-white border border-gray-100 shadow-2xl shadow-gray-200/50"
    },
    "padding": {
      "none": "",
      "sm": "p-4",
      "md": "p-6",
      "lg": "p-8",
      "xl": "p-12"
    },
    "radius": {
      "none": "rounded-none",
      "xl": "rounded-xl",
      "2xl": "rounded-2xl",
      "3xl": "rounded-3xl",
      "4xl": "rounded-[2rem]",
      "full": "rounded-[2.5rem]"
    }
  },
  "defaultVariants": {
    "variant": "default",
    "padding": "md",
    "radius": "3xl"
  }
}
