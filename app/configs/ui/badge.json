  "variants": {
    "color": {
      "primary": "bg-teal-50 border-teal-100 text-primary",
      "secondary": "bg-gray-100 border-gray-200 text-secondary",
      "white": "bg-white border-gray-200 text-secondary",
      "emerald": "bg-emerald-50 border-emerald-100 text-emerald-600"
    },
    "size": {
      "sm": "px-3 py-1.5 text-[9px]",
      "md": "px-4 py-2 text-[10px]"
    }
