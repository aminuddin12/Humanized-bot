{
  "name": "Humanized-bot",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "npx kill-port 3000 && nuxt dev",
    "generate": "prisma generate",
    "preview": "nuxt preview",
    "test": "vitest run",
    "start": "npx kill-port 3000 && node .output/server/index.mjs",
    "db:seed": "npx tsx prisma/seeders/seed.ts",
    "postinstall": "prisma generate && nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "prisma": {
    "schema": "prisma/schema"
  },
  "dependencies": {
    "@nuxt/a11y": "^1.0.0-alpha.1",
    "@nuxt/content": "^3.12.0",
    "@nuxt/devtools": "^3.2.3",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/i18n": "^10.2.3",
    "@vueuse/core": "^14.2.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.3",
    "nuxt": "^4.4.2",
    "pino": "^10.3.1",
    "socket.io": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fluent": "^1.2.40",
    "@iconify-json/logos": "^1.2.10",
    "@iconify-json/ri": "^1.2.10",
    "@nuxt/eslint": "^1.15.2",
    "@prisma/client": "^6.19.2",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@vue/test-utils": "^2.4.6",
    "better-sqlite3": "^12.6.2",
    "eslint": "^10.0.3",
    "happy-dom": "^20.8.4",
    "prisma": "^6.19.2",
    "vitest": "^4.1.0"
  }
}
